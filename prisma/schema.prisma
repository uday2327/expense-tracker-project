generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
  SHARES
}

enum Currency {
  INR
  USD
}

enum ImportStatus {
  PENDING_REVIEW
  CONFIRMED
  REJECTED
}

enum AuditAction {
  CREATE_GROUP
  ADD_MEMBER
  REMOVE_MEMBER
  CREATE_EXPENSE
  UPDATE_EXPENSE
  DELETE_EXPENSE
  CREATE_SETTLEMENT
  CREATE_IMPORT_SESSION
  CONFIRM_IMPORT
  REJECT_IMPORT
}

enum AnomalyType {
  DUPLICATE_ROW
  DUPLICATE_EXPENSE
  SETTLEMENT_AS_EXPENSE
  CURRENCY_MISMATCH
  MEMBER_LEFT
  MEMBER_NOT_YET_JOINED
  NEGATIVE_AMOUNT
  INCONSISTENT_DATE_FORMAT
  MISSING_FIELD
  NAME_MISMATCH
  UNKNOWN_MEMBER
  SPLIT_DOESNT_ADD_UP
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  passwordHash String @map("password_hash")
  createdAt DateTime @default(now()) @map("created_at")

  memberships       GroupMember[]
  paidExpenses      Expense[]       @relation("ExpensePayer")
  splits            ExpenseSplit[]
  paidSettlements   Settlement[]    @relation("SettlementPayer")
  receivedSettlements Settlement[]  @relation("SettlementReceiver")
  approvedAnomalies ImportAnomaly[] @relation("AnomalyApprover")
  uploadedImports   ImportSession[] @relation("ImportUploader")
  confirmedImports  ImportSession[] @relation("ImportConfirmer")
  rejectedImports   ImportSession[] @relation("ImportRejecter")
  auditLogs         AuditLog[]

  @@map("users")
}

model Group {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  importSessions ImportSession[]
  auditLogs   AuditLog[]

  @@map("groups")
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String   @map("group_id")
  userId   String   @map("user_id")
  joinedAt DateTime @map("joined_at") @db.Date
  leftAt   DateTime? @map("left_at") @db.Date

  group Group @relation(fields: [groupId], references: [id], onDelete: Restrict)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([groupId, joinedAt, leftAt])
  @@unique([groupId, userId, joinedAt])
  @@map("group_members")
}

model Expense {
  id              String    @id @default(uuid())
  groupId         String    @map("group_id")
  paidByUserId    String    @map("paid_by_user_id")
  description     String
  totalAmount     Decimal   @map("total_amount") @db.Decimal(12, 2)
  currency        Currency
  amountInInr     Decimal   @map("amount_in_inr") @db.Decimal(12, 2)
  splitType       SplitType @map("split_type")
  expenseDate     DateTime  @map("expense_date") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  isFlaggedAnomaly Boolean  @default(false) @map("is_flagged_anomaly")
  anomalyReason   String?   @map("anomaly_reason")

  group  Group @relation(fields: [groupId], references: [id], onDelete: Restrict)
  paidBy User  @relation("ExpensePayer", fields: [paidByUserId], references: [id], onDelete: Restrict)
  splits ExpenseSplit[]

  @@index([groupId, expenseDate])
  @@index([paidByUserId])
  @@map("expenses")
}

model ExpenseSplit {
  id         String  @id @default(uuid())
  expenseId  String  @map("expense_id")
  userId     String  @map("user_id")
  amountOwed Decimal @map("amount_owed") @db.Decimal(12, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([expenseId, userId])
  @@index([userId])
  @@map("expense_splits")
}

model Settlement {
  id           String   @id @default(uuid())
  groupId      String   @map("group_id")
  paidByUserId String   @map("paid_by_user_id")
  paidToUserId String   @map("paid_to_user_id")
  amount       Decimal  @db.Decimal(12, 2)
  settledAt    DateTime @map("settled_at")

  group  Group @relation(fields: [groupId], references: [id], onDelete: Restrict)
  paidBy User  @relation("SettlementPayer", fields: [paidByUserId], references: [id], onDelete: Restrict)
  paidTo User  @relation("SettlementReceiver", fields: [paidToUserId], references: [id], onDelete: Restrict)
  importSessionId String? @map("import_session_id")
  importSession   ImportSession? @relation(fields: [importSessionId], references: [id], onDelete: SetNull)

  @@index([groupId, settledAt])
  @@index([importSessionId])
  @@map("settlements")
}

model ImportSession {
  id         String       @id @default(uuid())
  groupId    String?      @map("group_id")
  uploadedByUserId String? @map("uploaded_by_user_id")
  confirmedByUserId String? @map("confirmed_by_user_id")
  rejectedByUserId String? @map("rejected_by_user_id")
  filename   String
  importedAt DateTime     @default(now()) @map("imported_at")
  confirmedAt DateTime?   @map("confirmed_at")
  rejectedAt DateTime?    @map("rejected_at")
  rejectionReason String? @map("rejection_reason")
  status     ImportStatus @default(PENDING_REVIEW)
  stagedData Json         @default("[]") @map("staged_data")

  group      Group? @relation(fields: [groupId], references: [id], onDelete: Restrict)
  uploadedBy User?  @relation("ImportUploader", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  confirmedBy User? @relation("ImportConfirmer", fields: [confirmedByUserId], references: [id], onDelete: Restrict)
  rejectedBy User? @relation("ImportRejecter", fields: [rejectedByUserId], references: [id], onDelete: Restrict)
  anomalies ImportAnomaly[]
  settlements Settlement[]

  @@index([groupId, importedAt])
  @@index([uploadedByUserId])
  @@map("import_sessions")
}

model ImportAnomaly {
  id                 String      @id @default(uuid())
  importSessionId    String      @map("import_session_id")
  rowNumber          Int         @map("row_number")
  rawData            Json        @map("raw_data")
  anomalyType        AnomalyType @map("anomaly_type")
  anomalyDescription String      @map("anomaly_description")
  actionTaken        String      @map("action_taken")
  approvedByUserId   String?     @map("approved_by_user_id")
  approvedAt         DateTime?   @map("approved_at")

  importSession ImportSession @relation(fields: [importSessionId], references: [id], onDelete: Restrict)
  approvedBy    User?         @relation("AnomalyApprover", fields: [approvedByUserId], references: [id], onDelete: Restrict)

  @@index([importSessionId])
  @@map("import_anomalies")
}

model AuditLog {
  id        String      @id @default(uuid())
  action    AuditAction
  actorUserId String?   @map("actor_user_id")
  groupId   String?     @map("group_id")
  entityType String     @map("entity_type")
  entityId   String?    @map("entity_id")
  metadata  Json        @default("{}")
  createdAt DateTime    @default(now()) @map("created_at")

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  group Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([groupId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model ExchangeRate {
  id          String   @id @default(uuid())
  fromCurrency Currency @map("from_currency")
  toCurrency   Currency @map("to_currency")
  rate        Decimal  @db.Decimal(18, 6)
  effectiveOn DateTime @map("effective_on") @db.Date
  source      String   @default("manual")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([fromCurrency, toCurrency, effectiveOn])
  @@index([fromCurrency, toCurrency, effectiveOn])
  @@map("exchange_rates")
}
